# Excluimos del contexto de build todo lo que no hace falta.
# Esto acelera los builds de Docker y evita que node_modules del host
# (si existiera) pise el del contenedor.
node_modules
dist
.git
.gitignore
*.log
.DS_Store
.env
.env.*
.vscode
.idea

# Tests y manifiestos de k8s no se necesitan en la imagen de producción.
tests
k8s

# Config de opencode y otros archivos de desarrollo.
opencode.json
.opencode
AGENTS.md

